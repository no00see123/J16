# ========== Vrtex Clash Final Evolution 2026-03-07 ==========
# 核心：Loyalsoldier + blackmatrix7 | 模式：极速白名单
mixed-port: 7890
allow-lan: true
mode: rule
log-level: info
ipv6: false

dns:
  enable: true
  listen: 0.0.0.0:53
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - https://doh.pub/dns-query
  fallback:
    - tls://8.8.8.8:853
    - https://dns.google/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN

proxies:
  - name: "示例节点 | 替换为你的订阅"
    type: ss
    server: server.vrtex.com
    port: 443
    cipher: 2022-blake3-aes-128-gcm
    password: "password"

proxy-groups:
  - name: 🚀 节点选择
    type: select
    proxies: [♻️ 自动选择, 🇭🇰 香港节点, 🇸🇬 新加坡节点, 🇺🇲 美国节点, DIRECT]

  - name: ♻️ 自动选择
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 40
    lazy: true
    proxies: [ "示例节点 | 替换为你的订阅" ]

  - name: 🌏 跨境电商
    type: fallback
    proxies: [🇺🇲 美国节点, 🇭🇰 香港节点, 🇸🇬 新加坡节点, 🇯🇵 日本节点]
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 🛡️ 特种服务
    type: fallback
    proxies: [🇺🇲 美国节点, 🇭🇰 香港节点, 🇸🇬 新加坡节点, 🚀 节点选择]
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 🌐 大众服务
    type: select
    proxies: [♻️ 自动选择, 🚀 节点选择]

  - name: 🐟 漏网之鱼
    type: select
    proxies: [🚀 节点选择, ♻️ 自动选择, DIRECT]

  # 地域组建议配合订阅转换器（如 Sub-Store）自动生成，此处为逻辑占位
  - name: 🇭🇰 香港节点
    type: select
    proxies: [DIRECT]
  - name: 🇺🇲 美国节点
    type: select
    proxies: [DIRECT]
  - name: 🇸🇬 新加坡节点
    type: select
    proxies: [DIRECT]
  - name: 🇯🇵 日本节点
    type: select
    proxies: [DIRECT]

rule-providers:
  private:
    type: http
    behavior: domain
    url: "https://raw.githubusercontent.com/Loyalsoldier/clash-rules/release/private.txt"
    path: ./ruleset/private.yaml
    interval: 86400

  direct:
    type: http
    behavior: domain
    url: "https://raw.githubusercontent.com/Loyalsoldier/clash-rules/release/direct.txt"
    path: ./ruleset/direct.yaml
    interval: 86400

  tiktok:
    type: http
    behavior: classical
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/TikTok/TikTok.list"
    path: ./ruleset/tiktok.yaml
    interval: 86400

  openai:
    type: http
    behavior: classical
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/OpenAI/OpenAI.list"
    path: ./ruleset/openai.yaml
    interval: 86400

rules:
  - RULE-SET,private,DIRECT
  - RULE-SET,direct,DIRECT
  - RULE-SET,tiktok,🌏 跨境电商
  - RULE-SET,openai,🛡️ 特种服务
  - GEOIP,CN,DIRECT,no-resolve
  - MATCH,🐟 漏网之鱼
